# Lattice local development environment variables.
# Copy this file to .env and fill in values. .env is git-ignored.

# NATS
NATS_URL=nats://localhost:4222
NATS_PORT=4222
NATS_HTTP_PORT=8222
# WebSocket listener — the browser Edge node's transport. Remap it alongside
# NATS_PORT when running side-by-side stacks, or the second stack fails to bind.
# 9222 is also Chrome's --remote-debugging-port default; override it here if a
# debug-enabled Chrome already holds the port.
NATS_WS_PORT=9222

# Postgres
POSTGRES_PASSWORD=lattice_dev
POSTGRES_PORT=5432
POSTGRES_DSN=postgres://lattice:lattice_dev@localhost:5432/lattice?sslmode=disable

# Bootstrap
# Path where the bootstrap config is persisted between runs.
BOOTSTRAP_JSON_PATH=./lattice.bootstrap.json

# Readiness gate timeout for `make up` (seconds).
BOOTSTRAP_READY_TIMEOUT_SEC=30
